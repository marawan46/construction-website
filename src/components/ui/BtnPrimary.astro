---
interface Props{
    text:string,
    link:string,
}
const {text, link} = Astro.props
---


<a href={link} class="group relative inline-flex items-center justify-center p-3 md:px-8 md:py-3 font-bold text-slate-900 transition-all duration-300 bg-amber-400 rounded-md overflow-hidden hover:bg-amber-300 hover:shadow-[0_0_20px_rgba(251,191,36,0.4)] active:scale-95">
    <div class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-linear-to-r from-transparent via-white/40 to-transparent"></div>

<span class="relative text-sm md:text-lg z-10 flex items-center gap-2">
    {text}
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 transition-transform group-hover:translate-x-1 rtl:group-hover:-translate-x-1">
    <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
    </svg>
</span>
</a>