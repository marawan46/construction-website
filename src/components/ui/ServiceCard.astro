---
import { Axis3d, ArrowRight } from 'lucide-react';
interface Props {
    img:string,
    title:string,
    description:string,
    icon:string,
}
const {img, title, description ,icon} = Astro.props
---

<article class="group relative bg-slate-100 border border-slate-200 rounded-none shadow-sm hover:-translate-y-2 transition-all duration-300 flex flex-col overflow-visible">
    
    <div class="relative w-full h-60 overflow-hidden">
    <img 
        src={img} 
        alt="General Construction" 
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
    />
    <div class="absolute inset-0 bg-linear-to-t from-primary/80 from-10% to-transparent to-40% opacity-60"></div>
    </div>

    <div class="relative h-px bg-primary mx-4">
    <div class="absolute text-amber-700 top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-14 h-14 bg-amber-100 rounded-full flex items-center justify-center border-4 border-amber-400 z-10 shadow-[0_0_0_4px_rgba(200,146,42,0.1)] transition-all duration-300 group-hover:scale-110 group-hover:shadow-[0_0_0_8px_rgba(200,146,42,0.15)]">
        <Axis3d />
    </div>
    </div>

    <div class="flex flex-col flex-1 px-8 pt-10 pb-8">
    <h3 class="text-2xl font-bold text-primary uppercase tracking-tight">{title}</h3>
    <p class="text-slate-500 text-sm leading-relaxed mt-4 flex-1">
        {description}
    </p>
    
    <!-- <button class="relative mt-8 overflow-hidden border border-primary text-primary text-xs tracking-widest uppercase py-4 px-6 font-bold group/btn transition-colors duration-300">
        <span class="relative z-10 group-hover/btn:text-white transition-colors">Learn More</span>
        <div class="absolute top-0 -left-full w-full h-full bg-primary transition-all duration-300 group-hover/btn:left-0 z-0"></div>
    </button> -->
    </div>
</article>