---
const { pathname } = Astro.url;

// دالة بتبدل كود اللغة في اللينك
function getTargetLink(lang: 'ar' | '') {
  const segments = pathname.split('/').filter(Boolean);
  
  if (segments[0] === 'ar' || segments[0] === 'en') {
    segments[0] = lang;
  } else {
    segments.unshift(lang);
  }
  
  return `/${segments.join('/')}`;
}

const currentLang = pathname.startsWith('/ar') ? 'ar' : '/';
---

<div class="lang-switcher flex items-center">
  {currentLang === '/' ? (
    <a href={getTargetLink('ar')} class="lang-btn">
      <span class="icon">🇪🇬</span> العربية
    </a>
  ) : (
    <a href={getTargetLink('')} class="lang-btn">
      <span class="icon">🇺🇸</span> English
    </a>
  )}
</div>

<style>
  .lang-switcher {
    margin: 0 1rem;
    display: flex;
    align-items: center;
  }
  .lang-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: #333; /* لون يليق بشركة مقاولات */
    color: #ffb400; /* اللون الأصفر بتاعنا */
    text-decoration: none;
    border-radius: 4px;
    font-weight: bold;
    transition: background 0.3s;
  }
  .lang-btn:hover {
    background: #444;
  }
</style>