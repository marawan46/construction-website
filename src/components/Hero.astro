---
import BtnPrimary from "./ui/BtnPrimary.astro";

// Define your images here
const images = [
  { src: "projects/p1.jpg", alt: "Project One" },
  { src: "projects/p2.jpg", alt: "Project Two" },
  { src: "projects/p3.jpg", alt: "Project Three" },
  { src: "projects/p4.jpg", alt: "Project Four" },
];

import { getTranslations } from '../i18n/ui';

const lang = Astro.currentLocale as 'en' | 'ar';

let t = await getTranslations(lang as 'ar' | 'en');

---

<section class="relative min-h-90 lg:h-screen bg-slate-100 grid lg:grid-cols-12 items-center pt-20 pb-10 gap-8">
     <div class="absolute z-40 inset-0 pointer-events-none filter opacity-30 
               bg-radial-[at_50%_75%] from-sky-200 via-blue-400 to-indigo-900 to-90%">
  </div>

  {images.map((img, i) => (
    <img
      src={img.src}
      alt={img.alt}
      data-bg
      data-index={i}
      class="bg-slide absolute inset-0 brightness-50 blur-sm w-full h-full object-cover transition-opacity duration-700 opacity-0"
    />
  ))}

  <div class="relative z-50 px-8 pt-8 lg:p-20 lg:col-span-5 space-y-6">
    <div class="flex flex-col gap-5 lg:gap-10">
    <h1 class="text-white text-[clamp(2rem,-0.9091rem+11.6364vw,3.5rem)] text-center md:text-start font-bold leading-tight uppercase">
      {t.hero.heading}
    </h1>
    <p class="text-gray-950 text-md md:max-w-xs font-bold flex text-center md:text-start items-center lg:items-start">{t.hero.subheading}</p>

    </div>

      <BtnPrimary text={t.nav.quote} link='#contact' />

  </div>

  <div class="lg:col-span-7 flex flex-col md:flex-row gap-4 p-5 md:p-0 h-100 lg:h-140">

  <!-- CURRENT SLIDE -->
  <div class="current-slide flex-1 z-50 rounded-lg bg-slate-500/20 border border-white/10 flex items-center justify-center relative overflow-hidden">
    {images.map((img, i) => (
      <img
        src={img.src}
        alt={img.alt}
        data-main
        data-index={i}
        class="main-slide absolute  shadow-2xl w-full h-full object-cover transition-opacity duration-700 opacity-0"
      />
    ))}
  </div>

  <!-- DOTS -->
  <div class="dots flex z-40  md:flex-col justify-center gap-2">
      {images.map((_, i) => (
        <div
          data-dot
          data-index={i}
          class="dot w-1.5 h-1.5 rounded-full bg-white/30"
        />
      ))}
  </div>

  <!-- NEXT SLIDE PEEK -->
  <div class="next-slide w-20 bg-slate-500/10 rounded-lg border-l border-white/10 hidden md:block relative overflow-hidden">
      {images.map((img, i) => (
        <img
          src={img.src}
          alt={img.alt}
          data-peek
          data-index={i}
          class="peek-slide absolute inset-0 filter blur-sm brightness-50 w-full h-full object-cover transition-opacity duration-700 opacity-0"
        />
      ))}
  </div>

</div>

</section>
<script>

  const bgSlides   = [...document.querySelectorAll('[data-bg]')];
  const mainSlides = [...document.querySelectorAll('[data-main]')];
  const peekSlides = [...document.querySelectorAll('[data-peek]')];
  const dots       = [...document.querySelectorAll('[data-dot]')];

  const total = mainSlides.length;
  let current = 0;

  function setActive(index) {
    const peekIndex = (index + 1) % total;

    // Reset all
    bgSlides.forEach(el => el.classList.remove('opacity-100'));
    mainSlides.forEach(el => el.classList.remove('opacity-100'));
    peekSlides.forEach(el => el.classList.remove('opacity-100'));
    dots.forEach(dot => dot.classList.replace('bg-white', 'bg-white/30'));

    // Activate current
    bgSlides[index].classList.add('opacity-100');
    mainSlides[index].classList.add('opacity-100');
    peekSlides[peekIndex].classList.add('opacity-100');
    dots[index].classList.replace('bg-white/30', 'bg-white');

    current = index;
  }

  function nextSlide() {
    setActive((current + 1) % total);
  }

  // Initialize
  setActive(0);

  // Auto play
  setInterval(nextSlide, 3000);

</script>