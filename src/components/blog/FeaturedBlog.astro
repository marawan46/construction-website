---
import { getCollection } from "astro:content";

// Only get featured, non-draft articles, sorted newest first
const allPosts = await getCollection("blog", ({ data }) => {
  return !data.draft && data.featured === true;
});
const featured = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
---

{featured.length > 0 && (
  <section class="featured-blog">
    <div class="featured-blog__inner">
      <header class="featured-blog__header">
        <div class="section-eyebrow">
          <span class="eyebrow-line"></span>
          <span>From the Field</span>
        </div>
        <div class="featured-blog__header-right">
          <h2 class="featured-blog__title">Latest Insights</h2>
          <a href="/blog" class="view-all-link">
            All Articles
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </header>

      <div class={`featured-grid featured-grid--${featured.length === 1 ? 'single' : featured.length === 2 ? 'double' : 'multi'}`}>
        {featured.map((post, i) => (
          <article class={`featured-card ${i === 0 ? 'featured-card--primary' : 'featured-card--secondary'}`}>
            <a href={`/blog/${post.slug}`} class="featured-card__link">
              {post.data.heroImage && (
                <div class="featured-card__image-wrap">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="featured-card__image"
                    loading={i === 0 ? "eager" : "lazy"}
                  />
                  <span class="featured-card__category">{post.data.category}</span>
                </div>
              )}
              <div class="featured-card__body">
                <time class="featured-card__date">{formatDate(post.data.pubDate)}</time>
                <h3 class="featured-card__heading">{post.data.title}</h3>
                <p class="featured-card__desc">{post.data.description}</p>
                <div class="featured-card__footer">
                  <span class="featured-card__author">{post.data.author}</span>
                  <span class="featured-card__cta">Read Article →</span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .featured-blog {
    padding: 6rem 0;
    background: var(--color-bg, #faf8f5);
  }
  .featured-blog__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .featured-blog__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3rem;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .section-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent, #c8791a);
    margin-bottom: 0.5rem;
  }
  .eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: currentColor;
  }
  .featured-blog__title {
    font-family: var(--font-display, 'Barlow Condensed', sans-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-heading, #1a1208);
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 0;
  }
  .view-all-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent, #c8791a);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    white-space: nowrap;
    transition: gap 0.2s;
  }
  .view-all-link:hover { gap: 0.75rem; }

  /* Grid layouts */
  .featured-grid {
    display: grid;
    gap: 1.5px;
    background: var(--color-border, #d4c8b8);
  }
  .featured-grid--single { grid-template-columns: 1fr; }
  .featured-grid--double { grid-template-columns: 1fr 1fr; }
  .featured-grid--multi { grid-template-columns: 1.6fr 1fr; }

  @media (max-width: 768px) {
    .featured-grid--double,
    .featured-grid--multi { grid-template-columns: 1fr; }
  }

  /* Cards */
  .featured-card { background: var(--color-bg, #faf8f5); }
  .featured-card__link {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }
  .featured-card__image-wrap {
    position: relative;
    overflow: hidden;
  }
  .featured-card--primary .featured-card__image-wrap { aspect-ratio: 16/9; }
  .featured-card--secondary .featured-card__image-wrap { aspect-ratio: 4/3; }
  .featured-grid--single .featured-card__image-wrap { aspect-ratio: 21/9; }

  .featured-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .featured-card__link:hover .featured-card__image { transform: scale(1.03); }
  .featured-card__category {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--color-accent, #c8791a);
    color: white;
    padding: 0.3rem 0.7rem;
  }
  .featured-card__body {
    padding: 1.75rem 2rem;
  }
  .featured-card--secondary .featured-card__body { padding: 1.25rem 1.5rem; }
  .featured-card__date {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted, #8a7a6a);
    margin-bottom: 0.75rem;
  }
  .featured-card__heading {
    font-family: var(--font-display, 'Barlow Condensed', sans-serif);
    font-size: clamp(1.3rem, 2.5vw, 2rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-heading, #1a1208);
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }
  .featured-card--secondary .featured-card__heading { font-size: clamp(1rem, 1.8vw, 1.4rem); }
  .featured-card__desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-muted, #8a7a6a);
    margin: 0 0 1.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .featured-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .featured-card__author {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted, #8a7a6a);
  }
  .featured-card__cta {
    color: var(--color-accent, #c8791a);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: letter-spacing 0.2s;
  }
  .featured-card__link:hover .featured-card__cta { letter-spacing: 0.14em; }
</style>
