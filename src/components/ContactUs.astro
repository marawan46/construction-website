---
import QuoteForm from '../components/QuoteForm'
import { getTranslations } from '../i18n/ui';

const lang = Astro.currentLocale as 'en' | 'ar';

let t = await getTranslations(lang as 'ar' | 'en');
---

<section id="contact" class="relative bg-gray-900 text-white py-24 px-6 overflow-hidden">

  <!-- Subtle Grid Background -->
  <div class="absolute inset-0 -z-10 
              bg-[linear-gradient(to_right,#374151_1px,transparent_1px),
                  linear-gradient(to_bottom,#374151_1px,transparent_1px)]
              bg-size-[60px_60px] opacity-20">
  </div>

  <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">

    <!-- Left Content -->
    <div class="space-y-8">

      <p class="text-sm uppercase tracking-widest text-amber-400">
        {t.nav.quote}
      </p>

      <h2 class="text-4xl md:text-5xl font-bold leading-tight">
        {t.contactSection.heading}
      </h2>

      <p class="text-gray-300 max-w-xl">
        {t.contactSection.subheading}
      </p>

      <!-- Trust Points -->
      <!-- <div class="space-y-4 text-gray-300 text-sm">
        <p>✔️ 20+ Years Industry Experience</p>
        <p>✔️ Licensed & Certified Engineers</p>
        <p>✔️ Transparent Pricing Structure</p>
      </div> -->

    </div>

    <!-- Form -->
    <div class="bg-white text-gray-900 rounded-3xl p-10 shadow-2xl">

<QuoteForm client:load />

    </div>

  </div>

</section>