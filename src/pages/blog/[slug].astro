---
import { getCollection, render } from "astro:content";
import BeforeAfter from "../../components/blog/BeforeAfter.astro";
import Callout from '../../components/blog/Callout.astro';
import StatBlock from '../../components/blog/StatBlock.astro';
import ProjectTimeLine from '../../components/blog/ProjectTimeline.astro'
export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as any;
const { Content, headings } = await render(post);

// Get related posts (same category, not this one)
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const related = allPosts
  .filter((p) => p.slug !== post.slug && p.data.category === post.data.category)
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title} — Construction Co.</title>
    <meta name="description" content={post.data.description} />
    {post.data.heroImage && <meta property="og:image" content={post.data.heroImage} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>

    <article class="article-page">

      <!-- Hero -->
      <header class="article-hero">
        {post.data.heroImage ? (
          <div class="article-hero__image-wrap">
            <img src={post.data.heroImage} alt={post.data.title} class="article-hero__image" />
            <div class="article-hero__overlay" />
          </div>
        ) : (
          <div class="article-hero__bg" />
        )}

        <div class="article-hero__content">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">·</span>
            <a href="/blog">Blog</a>
            <span aria-hidden="true">·</span>
            <span>{post.data.category}</span>
          </nav>

          <div class="article-hero__meta">
            <span class="meta-category">{post.data.category}</span>
            <span class="meta-divider" aria-hidden="true">·</span>
            <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            <span class="meta-divider" aria-hidden="true">·</span>
            <span>{readingTime} min read</span>
          </div>

          <h1 class="article-hero__title">{post.data.title}</h1>
          <p class="article-hero__desc">{post.data.description}</p>

          <div class="article-hero__author">
            <div class="author-avatar" aria-hidden="true">
              {post.data.author.split(' ').map(n => n[0]).join('').slice(0, 2)}
            </div>
            <div>
              <div class="author-name">{post.data.author}</div>
              {post.data.updatedDate && (
                <div class="author-updated">Updated {formatDate(post.data.updatedDate)}</div>
              )}
            </div>
          </div>
        </div>
      </header>

      <!-- Content + Sidebar -->
      <div class="article-layout">

        <!-- Table of Contents (sidebar) -->
        {headings.length > 2 && (
          <aside class="article-toc" aria-label="Table of contents">
            <div class="toc-inner">
              <div class="toc-label">Contents</div>
              <nav>
                <ol class="toc-list">
                  {headings.filter(h => h.depth <= 2).map((h) => (
                    <li class={`toc-item toc-item--h${h.depth}`}>
                      <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
                    </li>
                  ))}
                </ol>
              </nav>
            </div>
          </aside>
        )}

        <!-- Article body -->
        <div class="article-body">
          <div class="article-content prose">
            <Content components={{Callout,BeforeAfter,StatBlock,ProjectTimeLine}}/>
          </div>

          <!-- Tags -->
          {post.data.tags.length > 0 && (
            <footer class="article-tags">
              <span class="tags-label">Topics</span>
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </footer>
          )}
        </div>
      </div>

      <!-- Related articles -->
      {related.length > 0 && (
        <section class="related-section" aria-label="Related articles">
          <div class="related-inner">
            <div class="related-header">
              <span class="section-eyebrow">More to Read</span>
              <h2 class="related-title">Related Articles</h2>
            </div>
            <div class="related-grid">
              {related.map((rp) => (
                <a href={`/blog/${rp.slug}`} class="related-card">
                  {rp.data.heroImage && (
                    <div class="related-card__image-wrap">
                      <img src={rp.data.heroImage} alt={rp.data.title} class="related-card__image" loading="lazy" />
                    </div>
                  )}
                  <div class="related-card__body">
                    <span class="related-card__category">{rp.data.category}</span>
                    <h3 class="related-card__title">{rp.data.title}</h3>
                    <time class="related-card__date">{formatDate(rp.data.pubDate)}</time>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Back link -->
      <div class="back-section">
        <a href="/blog" class="back-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M13 8H3M7 12L3 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Back to all articles
        </a>
      </div>

    </article>

    <!-- Reading progress bar -->
    <div class="progress-bar" id="progress-bar" aria-hidden="true"></div>

    <script>
      const bar = document.getElementById('progress-bar')!;
      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = Math.min((scrollTop / docHeight) * 100, 100);
        bar.style.width = progress + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });

      // Smooth-highlight active ToC link
      const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
      const headings = document.querySelectorAll<HTMLElement>('h2, h3');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('toc-link--active'));
            const active = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
            if (active) active.classList.add('toc-link--active');
          }
        });
      }, { rootMargin: '-20% 0px -75% 0px' });

      headings.forEach(h => observer.observe(h));
    </script>

  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-bg: #faf8f5;
    --color-surface: #f2ede6;
    --color-border: #d4c8b8;
    --color-text: #2a2015;
    --color-heading: #1a1208;
    --color-muted: #8a7a6a;
    --color-accent: #c8791a;
    --font-display: 'Barlow Condensed', sans-serif;
    --font-body: 'Lora', Georgia, serif;
  }

  body {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
  }

  /* Reading progress */
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    background: var(--color-accent);
    z-index: 999;
    width: 0%;
    transition: width 0.1s linear;
  }

  /* Hero */
  .article-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
    background: var(--color-heading);
    overflow: hidden;
  }
  .article-hero__image-wrap {
    position: absolute;
    inset: 0;
  }
  .article-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.4;
  }
  .article-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--color-accent) 0%, rgba(255, 231, 201, 0) 100%);
  }
  .article-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--color-heading);
  }
  .article-hero__content {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
    width: 100%;
  }

  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35);
    margin-bottom: 2rem;
  }
  .breadcrumb a { color: rgba(255,255,255,0.5); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); }

  .article-hero__meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.45);
    margin-bottom: 1rem;
  }
  .meta-category { color: var(--color-accent); font-weight: 700; }
  .meta-divider { opacity: 0.4; }

  .article-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 4.5rem);
    font-weight: 800;
    color: white;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1.02;
    max-width: 800px;
    margin-bottom: 1.25rem;
  }
  .article-hero__desc {
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.6);
    max-width: 600px;
    margin-bottom: 2rem;
  }
  .article-hero__author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .author-avatar {
    width: 40px;
    height: 40px;
    background: var(--color-muted);
    color: white;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .author-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: white;
  }
  .author-updated {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.15rem;
  }

  /* Layout */
  .article-layout {
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 2rem 4rem;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 4rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .article-layout { grid-template-columns: 1fr; gap: 2rem; }
    .article-toc { display: none; }
  }

  /* ToC */
  .article-toc {
    position: sticky;
    top: 5rem;
  }
  .toc-inner { padding: 0; }
  .toc-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .toc-list { list-style: none; display: flex; flex-direction: column; gap: 0; }
  .toc-item { }
  .toc-link {
    display: block;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--color-muted);
    text-decoration: none;
    padding: 0.4rem 0 0.4rem 0.75rem;
    border-left: 2px solid var(--color-border);
    transition: color 0.2s, border-color 0.2s;
  }
  .toc-link:hover,
  .toc-link--active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }
  .toc-item--h3 .toc-link { padding-left: 1.5rem; font-size: 0.75rem; }

  /* Prose styles */
  .prose {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
    max-width: 72ch;
  }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--color-heading);
    margin: 3rem 0 1rem;
    padding-top: 1rem;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-heading);
    margin: 2rem 0 0.75rem;
  }
  .prose :global(p) { margin-bottom: 1.5rem; }
  .prose :global(strong) { font-weight: 600; color: var(--color-heading); }
  .prose :global(em) { font-style: italic; }
  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(ul), .prose :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }
  .prose :global(li) { margin-bottom: 0.5rem; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: var(--color-surface);
    font-style: italic;
  }
  .prose :global(code) {
    font-size: 0.85em;
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: 2px;
  }
  .prose :global(pre) {
    background: var(--color-heading);
    color: rgba(255,255,255,0.85);
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }
  .prose :global(img) {
    max-width: 100%;
    display: block;
    margin: 2rem 0;
  }

  /* Tags */
  .article-tags {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .tags-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    margin-right: 0.5rem;
  }
  .tag {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-surface);
    color: var(--color-muted);
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-border);
  }

  /* Related */
  .related-section {
    background: var(--color-heading);
    padding: 5rem 0;
  }
  .related-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .related-header { margin-bottom: 2.5rem; }
  .section-eyebrow {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }
  .related-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    text-transform: uppercase;
    color: white;
    letter-spacing: -0.02em;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(260px, 2fr));
    gap: 1.5px;
    background: rgba(255,255,255,0.08);
  }
  .related-card {
    background: rgba(255,255,255,0.04);
    text-decoration: none;
    color: inherit;
    display: block;
    transition: background 0.2s;
  }
  .related-card:hover { background: rgba(255,255,255,0.07); }
  .related-card__image-wrap {
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .related-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
    transition: opacity 0.3s;
  }
  .related-card:hover .related-card__image { opacity: 0.8; }
  .related-card__body { padding: 1.25rem 1.5rem; }
  .related-card__category {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }
  .related-card__title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    color: white;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }
  .related-card__date {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Back */
  .back-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    border-top: 1px solid var(--color-border);
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s, gap 0.2s;
  }
  .back-link:hover { color: var(--color-accent); gap: 0.75rem; }
</style>